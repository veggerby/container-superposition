{
    "$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainer.base.schema.json",
    "features": {
        "./features/cross-distro-packages": {
            "apt": "curl",
            "apk": "curl"
        }
    },
    "runServices": ["nats{{cs.CS_INSTANCE_SUFFIX}}"],
    "forwardPorts": ["{{cs.NATS_CLIENT_PORT}}", "{{cs.NATS_HTTP_PORT}}"],
    "portsAttributes": {
        "{{cs.NATS_CLIENT_PORT}}": {
            "label": "NATS Client Port",
            "onAutoForward": "notify"
        },
        "{{cs.NATS_HTTP_PORT}}": {
            "label": "NATS Monitoring",
            "onAutoForward": "openBrowser"
        }
    },
    "remoteEnv": {
        "NATS_URL{{cs.CS_INSTANCE_ENV_SUFFIX}}": "nats://nats{{cs.CS_INSTANCE_SUFFIX}}:{{cs.NATS_CLIENT_PORT}}"
    }
}
