{
    "$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainer.base.schema.json",
    "features": {
        "./features/cross-distro-packages": {
            "apt": "redis-tools",
            "apk": "redis"
        }
    },
    "runServices": ["redis{{cs.CS_INSTANCE_SUFFIX}}"],
    "forwardPorts": ["{{cs.REDIS_PORT}}"],
    "portsAttributes": {
        "{{cs.REDIS_PORT}}": {
            "label": "Redis",
            "onAutoForward": "notify"
        }
    },
    "remoteEnv": {
        "REDIS_HOST{{cs.CS_INSTANCE_ENV_SUFFIX}}": "redis{{cs.CS_INSTANCE_SUFFIX}}",
        "REDIS_PORT{{cs.CS_INSTANCE_ENV_SUFFIX}}": "{{cs.REDIS_PORT}}"
    }
}
