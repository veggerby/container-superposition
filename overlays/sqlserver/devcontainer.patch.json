{
    "$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainer.base.schema.json",
    "customizations": {
        "vscode": {
            "extensions": ["ms-mssql.mssql"]
        }
    },
    "runServices": ["sqlserver{{cs.CS_INSTANCE_SUFFIX}}"],
    "forwardPorts": ["{{cs.MSSQL_PORT}}"],
    "portsAttributes": {
        "{{cs.MSSQL_PORT}}": {
            "label": "SQL Server",
            "onAutoForward": "notify"
        }
    },
    "remoteEnv": {
        "MSSQL_HOST{{cs.CS_INSTANCE_ENV_SUFFIX}}": "sqlserver{{cs.CS_INSTANCE_SUFFIX}}",
        "MSSQL_PORT{{cs.CS_INSTANCE_ENV_SUFFIX}}": "{{cs.MSSQL_PORT}}",
        "MSSQL_SA_PASSWORD{{cs.CS_INSTANCE_ENV_SUFFIX}}": "{{cs.MSSQL_SA_PASSWORD}}",
        "MSSQL_DATABASE{{cs.CS_INSTANCE_ENV_SUFFIX}}": "master"
    }
}
