# ComfyUI Configuration

# Root path for ComfyUI model files on the host.
# Subdirectories (checkpoints, loras, vae, controlnet, embeddings, upscale_models)
# are mounted individually so ComfyUI discovers each model type correctly.
# Point this at an existing ComfyUI models dir to reuse already-downloaded models.
# NOTE: On Windows, set this explicitly — tilde expansion is unreliable in Docker Desktop.
# COMFYUI_MODELS_PATH=~/ComfyUI/models
COMFYUI_MODELS_PATH=~/.cache/comfyui/models

# Where generated images/videos are saved on the host.
# Outputs survive container restarts and rebuilds.
COMFYUI_OUTPUT_PATH=~/.cache/comfyui/output

# ComfyUI Docker image tag. Use 'latest-cuda' for NVIDIA GPU, 'latest-rocm' for AMD/ROCm, or 'latest-cpu' for CPU-only.
COMFYUI_VERSION=latest-cuda

# Host port for the ComfyUI web UI. Default: 8188.
COMFYUI_PORT=8188

# Extra CLI arguments passed to ComfyUI at startup.
# --listen 0.0.0.0 is required to accept connections from outside the container.
CLI_ARGS=--listen 0.0.0.0
