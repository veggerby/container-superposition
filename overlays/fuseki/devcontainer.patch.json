{
    "$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainer.base.schema.json",
    "runServices": ["fuseki"],
    "_serviceOrder": 0,
    "forwardPorts": [3030],
    "portsAttributes": {
        "3030": {
            "label": "Fuseki SPARQL Server",
            "onAutoForward": "openBrowser"
        }
    },
    "remoteEnv": {
        "FUSEKI_HOST": "fuseki",
        "FUSEKI_PORT": "3030",
        "FUSEKI_DATASET": "{{cs.FUSEKI_DATASET}}",
        "FUSEKI_ADMIN_PASSWORD": "{{cs.FUSEKI_ADMIN_PASSWORD}}",
        "FUSEKI_URL": "http://fuseki:3030",
        "FUSEKI_SEED_FILE": "{{cs.FUSEKI_SEED_FILE}}",
        "FUSEKI_SEED_DIR": "{{cs.FUSEKI_SEED_DIR}}",
        "FUSEKI_SEED_MODE": "{{cs.FUSEKI_SEED_MODE}}",
        "FUSEKI_SEED_GRAPH": "{{cs.FUSEKI_SEED_GRAPH}}",
        "FUSEKI_SEED_CONTENT_TYPE": "{{cs.FUSEKI_SEED_CONTENT_TYPE}}"
    }
}
