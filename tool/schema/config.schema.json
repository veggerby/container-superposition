{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "title": "Container Superposition Configuration",
    "description": "Configuration for initializing a devcontainer with container-superposition",
    "properties": {
        "stack": {
            "type": "string",
            "enum": ["plain", "compose"],
            "description": "The base template to use (plain or compose)"
        },
        "baseImage": {
            "type": "string",
            "enum": ["bookworm", "trixie", "alpine", "ubuntu", "custom"],
            "default": "bookworm",
            "description": "Base image / Linux distro variant (or 'custom' for a user-defined image)"
        },
        "customImage": {
            "type": "string",
            "description": "Custom base image (only when baseImage is 'custom')"
        },
        "containerName": {
            "type": "string",
            "description": "Container/project name to write into devcontainer.json"
        },
        "preset": {
            "type": "string",
            "description": "Preset ID to expand during generation"
        },
        "presetChoices": {
            "type": "object",
            "additionalProperties": {
                "type": "string"
            },
            "description": "Preset parameter choices keyed by parameter name"
        },
        "overlays": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "alertmanager",
                    "amp",
                    "aws-cli",
                    "azure-cli",
                    "bun",
                    "claude-code",
                    "cloudflared",
                    "codex",
                    "commitlint",
                    "direnv",
                    "docker-in-docker",
                    "docker-sock",
                    "dotnet",
                    "duckdb",
                    "gcloud",
                    "gemini-cli",
                    "git-helpers",
                    "go",
                    "grafana",
                    "grpc-tools",
                    "jaeger",
                    "java",
                    "jupyter",
                    "just",
                    "keycloak",
                    "kind",
                    "kubectl-helm",
                    "localstack",
                    "loki",
                    "mailpit",
                    "minio",
                    "mkdocs",
                    "modern-cli-tools",
                    "mongodb",
                    "mysql",
                    "nats",
                    "ngrok",
                    "nodejs",
                    "openapi-tools",
                    "opencode",
                    "otel-collector",
                    "otel-demo-nodejs",
                    "otel-demo-python",
                    "pandoc",
                    "playwright",
                    "postgres",
                    "powershell",
                    "pre-commit",
                    "prometheus",
                    "promtail",
                    "pulumi",
                    "python",
                    "rabbitmq",
                    "redis",
                    "redpanda",
                    "rust",
                    "spec-kit",
                    "sqlite",
                    "sqlserver",
                    "tempo",
                    "terraform",
                    "tilt",
                    "windsurf-cli"
                ]
            },
            "default": [],
            "description": "Flat list of overlay IDs to include (preferred). Accepts any overlay regardless of category."
        },
        "language": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "dotnet",
                    "nodejs",
                    "python",
                    "mkdocs",
                    "java",
                    "go",
                    "rust",
                    "bun",
                    "jupyter",
                    "powershell"
                ]
            },
            "default": [],
            "description": "Deprecated: use 'overlays' instead. Language/framework overlays (kept for backward compatibility)."
        },
        "database": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "postgres",
                    "redis",
                    "mongodb",
                    "mysql",
                    "sqlserver",
                    "sqlite",
                    "duckdb",
                    "minio",
                    "rabbitmq",
                    "redpanda",
                    "nats"
                ]
            },
            "default": [],
            "description": "Deprecated: use 'overlays' instead. Database overlays (kept for backward compatibility)."
        },
        "playwright": {
            "type": "boolean",
            "default": false,
            "description": "Deprecated: use 'overlays: [playwright]' instead. Include Playwright for browser automation (kept for backward compatibility)."
        },
        "cloudTools": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "azure-cli",
                    "aws-cli",
                    "gcloud",
                    "cloudflared",
                    "kubectl-helm",
                    "kind",
                    "localstack",
                    "terraform",
                    "pulumi"
                ]
            },
            "default": [],
            "description": "Deprecated: use 'overlays' instead. Cloud/orchestration tools (kept for backward compatibility)."
        },
        "devTools": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "docker-in-docker",
                    "docker-sock",
                    "codex",
                    "playwright",
                    "git-helpers",
                    "grpc-tools",
                    "keycloak",
                    "mailpit",
                    "pre-commit",
                    "commitlint",
                    "just",
                    "direnv",
                    "modern-cli-tools",
                    "ngrok",
                    "openapi-tools",
                    "pandoc",
                    "spec-kit",
                    "tilt",
                    "claude-code",
                    "gemini-cli",
                    "amp",
                    "windsurf-cli",
                    "opencode"
                ]
            },
            "default": [],
            "description": "Deprecated: use 'overlays' instead. Developer tooling overlays (kept for backward compatibility)."
        },
        "observability": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "alertmanager",
                    "otel-collector",
                    "otel-demo-nodejs",
                    "otel-demo-python",
                    "jaeger",
                    "prometheus",
                    "promtail",
                    "grafana",
                    "loki",
                    "tempo"
                ]
            },
            "default": [],
            "description": "Deprecated: use 'overlays' instead. Observability tools (kept for backward compatibility)."
        },
        "portOffset": {
            "type": "number",
            "minimum": 0,
            "description": "Port offset for running multiple instances"
        },
        "outputPath": {
            "type": "string",
            "default": "./.devcontainer",
            "description": "Where to write the devcontainer configuration"
        },
        "target": {
            "type": "string",
            "enum": ["local", "codespaces", "gitpod", "devpod"],
            "description": "Target environment for compatibility checks"
        },
        "minimal": {
            "type": "boolean",
            "description": "Exclude optional overlays marked as minimal"
        },
        "editor": {
            "type": "string",
            "enum": ["vscode", "jetbrains", "none"],
            "description": "Editor customization profile"
        },
        "env": {
            "type": "object",
            "description": "Project-level environment variables routed to remoteEnv or docker-compose based on stack/target",
            "additionalProperties": {
                "oneOf": [
                    {
                        "type": "string"
                    },
                    {
                        "type": "object",
                        "properties": {
                            "value": { "type": "string" },
                            "target": {
                                "type": "string",
                                "enum": ["auto", "remoteEnv", "composeEnv"]
                            }
                        },
                        "required": ["value"],
                        "additionalProperties": false
                    }
                ]
            }
        },
        "mounts": {
            "description": "Project-level mount specs routed to devcontainer.json mounts or docker-compose volumes based on stack/target",
            "oneOf": [
                {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/projectMountEntry"
                    }
                },
                {
                    "type": "object",
                    "description": "Named mount map form",
                    "additionalProperties": {
                        "$ref": "#/$defs/projectMountObject"
                    }
                }
            ]
        },
        "shell": {
            "type": "object",
            "description": "Shell profile customizations written via a managed shell-init hook",
            "properties": {
                "aliases": {
                    "type": "object",
                    "additionalProperties": { "type": "string" },
                    "description": "Alias name -> command map (e.g. k: kubectl)"
                },
                "snippets": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Raw shell snippets appended to generated shell-init"
                }
            },
            "additionalProperties": false
        },
        "customizations": {
            "type": "object",
            "properties": {
                "devcontainerPatch": {
                    "type": "object",
                    "description": "Additional devcontainer.json content merged during generation"
                },
                "dockerComposePatch": {
                    "type": "object",
                    "description": "Additional docker-compose content merged during generation"
                },
                "envTemplate": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    },
                    "description": "Variables written to .env.example; use env for runtime container environment"
                },
                "environment": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    },
                    "description": "Deprecated alias for envTemplate; variables written to .env.example"
                },
                "scripts": {
                    "type": "object",
                    "properties": {
                        "postCreate": {
                            "type": "array",
                            "items": { "type": "string" }
                        },
                        "postStart": {
                            "type": "array",
                            "items": { "type": "string" }
                        }
                    },
                    "additionalProperties": false
                },
                "files": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "path": { "type": "string" },
                            "content": { "type": "string" }
                        },
                        "required": ["path", "content"],
                        "additionalProperties": false
                    }
                }
            },
            "additionalProperties": false
        }
    },
    "required": [],
    "additionalProperties": false,
    "$defs": {
        "projectMountTarget": {
            "type": "string",
            "enum": ["auto", "devcontainerMount", "composeVolume"]
        },
        "projectMountObject": {
            "type": "object",
            "properties": {
                "value": {
                    "type": "string",
                    "description": "Raw mount spec string (escape hatch)"
                },
                "source": { "type": "string", "description": "Mount source path or volume name" },
                "destination": { "type": "string", "description": "Container destination path" },
                "type": { "type": "string", "enum": ["bind", "volume", "tmpfs"] },
                "consistency": { "type": "string", "enum": ["consistent", "cached", "delegated"] },
                "cached": {
                    "type": "boolean",
                    "description": "Convenience alias for consistency: cached"
                },
                "readOnly": { "type": "boolean" },
                "target": { "$ref": "#/$defs/projectMountTarget" }
            },
            "additionalProperties": false,
            "oneOf": [{ "required": ["value"] }, { "required": ["source", "destination"] }]
        },
        "projectMountEntry": {
            "oneOf": [
                {
                    "type": "string",
                    "description": "Raw mount spec string"
                },
                {
                    "$ref": "#/$defs/projectMountObject"
                }
            ]
        }
    }
}
